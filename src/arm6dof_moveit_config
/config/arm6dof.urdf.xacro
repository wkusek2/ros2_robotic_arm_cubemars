<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="arm6dof">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import arm6dof urdf file -->
    <xacro:include filename="$(find arm6dof)/urdf/arm6dof.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="arm6dof.ros2_control.xacro" />


    <xacro:arm6dof_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
